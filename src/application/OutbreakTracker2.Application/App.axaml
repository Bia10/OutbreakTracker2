<Application
    x:Class="OutbreakTracker2.Application.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:suki="https://github.com/kikipoulet/SukiUI"
    RequestedThemeVariant="Default">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Dock.Avalonia.Themes.Fluent/Presets/Ide/Default.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <!--  Fallback inventory column counts — overridden by layout-specific ScrollViewer.Resources  -->
            <x:Int32 x:Key="InventorySlotColumns">2</x:Int32>
            <x:Int32 x:Key="EquippedSpecialColumns">2</x:Int32>
        </ResourceDictionary>
    </Application.Resources>
    <Application.Styles>
        <FluentTheme />
        <suki:SukiTheme Locale="en-US" ThemeColor="Blue" />
        <avalonia:MaterialIconStyles />
        <DockFluentTheme DensityStyle="Normal" />
    </Application.Styles>
</Application>