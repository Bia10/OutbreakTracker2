<UserControl
x:Class="OutbreakTracker2.Application.Views.Dashboard.ClientOverview.Inventory.ItemSlotView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:item="clr-namespace:OutbreakTracker2.Application.Views.Common.Item"
xmlns:inventory="clr-namespace:OutbreakTracker2.Application.Views.Dashboard.ClientOverview.Inventory"
d:DesignHeight="66"
d:DesignWidth="78"
x:DataType="inventory:ItemSlotViewModel"
mc:Ignorable="d">

    <UserControl.Resources>
        <!--  Defaults — overridden by ancestor ScrollViewer resources in InGamePlayersView  -->
        <x:Double x:Key="ItemSlotWidth">58</x:Double>
        <x:Double x:Key="ItemSlotHeight">50</x:Double>
    </UserControl.Resources>

    <Grid
    Width="{DynamicResource ItemSlotWidth}"
    Height="{DynamicResource ItemSlotHeight}"
    Margin="2">
        <item:ItemSlotControl />

        <!--  Glow border overlay — animated from code-behind when an inventory slot event is detected  -->
        <Border
        x:Name="GlowBorder"
        BorderThickness="3"
        CornerRadius="3"
        IsHitTestVisible="False"
        Opacity="0" />
    </Grid>
</UserControl>