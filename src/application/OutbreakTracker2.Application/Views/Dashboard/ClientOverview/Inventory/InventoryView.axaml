<UserControl
    x:Class="OutbreakTracker2.Application.Views.Dashboard.ClientOverview.Inventory.InventoryView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:inventory="clr-namespace:OutbreakTracker2.Application.Views.Dashboard.ClientOverview.Inventory"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="inventory:InventoryViewModel"
    mc:Ignorable="d">

    <StackPanel Spacing="3">
        <!-- Equipped + Special on one row -->
        <Grid ColumnDefinitions="Auto,Auto" HorizontalAlignment="Left">
            <StackPanel Grid.Column="0" Margin="0,0,6,0" Spacing="1">
                <TextBlock
                    FontSize="9"
                    Foreground="{DynamicResource SukiLowText}"
                    Text="Equipped" />
                <ItemsControl ItemsSource="{Binding EquippedItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="1">
                <TextBlock
                    FontSize="9"
                    Foreground="{DynamicResource SukiLowText}"
                    Text="Special" />
                <ItemsControl ItemsSource="{Binding SpecialItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <StackPanel IsVisible="{Binding !IsDeadOrZombie}" Spacing="1">
            <TextBlock
                FontSize="9"
                Foreground="{DynamicResource SukiLowText}"
                Text="Main" />
            <ItemsControl ItemsSource="{Binding MainSlots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" HorizontalAlignment="Left" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>

        <StackPanel IsVisible="{Binding IsSpecialInventoryVisible}" Spacing="1">
            <TextBlock
                FontSize="9"
                Foreground="{DynamicResource SukiLowText}"
                Text="Special" />
            <ItemsControl ItemsSource="{Binding SpecialSlots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" HorizontalAlignment="Left" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>

        <StackPanel IsVisible="{Binding IsDeadOrZombie}" Spacing="1">
            <TextBlock
                FontSize="9"
                Foreground="{DynamicResource SukiLowText}"
                Text="Dead" />
            <ItemsControl ItemsSource="{Binding DeadSlots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" HorizontalAlignment="Left" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>

        <StackPanel IsVisible="{Binding IsSpecialDeadInventoryVisible}" Spacing="1">
            <TextBlock
                FontSize="9"
                Foreground="{DynamicResource SukiLowText}"
                Text="Special dead" />
            <ItemsControl ItemsSource="{Binding SpecialDeadSlots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" HorizontalAlignment="Left" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>
    </StackPanel>
</UserControl>