<UserControl
    x:Class="OutbreakTracker2.Application.Views.Dashboard.ClientOverview.Inventory.InventoryView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:inventory="clr-namespace:OutbreakTracker2.Application.Views.Dashboard.ClientOverview.Inventory"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="inventory:InventoryViewModel"
    mc:Ignorable="d">

    <UserControl.DataTemplates>
        <!--
            Explicitly define ItemSlotViewModel → ItemSlotView here so Avalonia creates
            a fresh ItemSlotView per ItemsControl instead of hitting the app-level
            ViewLocator cache. The ViewLocator caches one view per ViewModel instance,
            so two ItemsControl panels sharing the same ItemSlotViewModel objects would
            get back the same cached ItemSlotView — causing the "already has a visual
            parent" crash when both panels are in the visual tree simultaneously.
        -->
        <DataTemplate DataType="{x:Type inventory:ItemSlotViewModel}">
            <inventory:ItemSlotView />
        </DataTemplate>
    </UserControl.DataTemplates>

    <StackPanel Spacing="6">
        <!-- Equipped + Special: side-by-side in horizontal, stacked in vertical -->
        <UniformGrid Columns="{DynamicResource EquippedSpecialColumns}" HorizontalAlignment="Left">
            <StackPanel Margin="0,0,6,0" Spacing="1">
                <TextBlock
                    FontSize="9"
                    Foreground="{DynamicResource SukiLowText}"
                    Text="Equipped" />
                <ItemsControl ItemsSource="{Binding EquippedItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
            <StackPanel Spacing="1">
                <TextBlock
                    FontSize="9"
                    Foreground="{DynamicResource SukiLowText}"
                    Text="Special" />
                <ItemsControl ItemsSource="{Binding SpecialItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </UniformGrid>

            <ItemsControl IsVisible="{Binding !IsDeadOrZombie}" ItemsSource="{Binding MainSlots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{DynamicResource InventorySlotColumns}" HorizontalAlignment="Left" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <ItemsControl IsVisible="{Binding IsSpecialInventoryVisible}" ItemsSource="{Binding SpecialSlots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{DynamicResource InventorySlotColumns}" HorizontalAlignment="Left" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <ItemsControl IsVisible="{Binding IsDeadOrZombie}" ItemsSource="{Binding DeadSlots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{DynamicResource InventorySlotColumns}" HorizontalAlignment="Left" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <ItemsControl IsVisible="{Binding IsSpecialDeadInventoryVisible}" ItemsSource="{Binding SpecialDeadSlots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{DynamicResource InventorySlotColumns}" HorizontalAlignment="Left" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
    </StackPanel>
</UserControl>