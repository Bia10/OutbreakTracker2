<UserControl
    x:Class="OutbreakTracker2.Application.Views.Dashboard.ClientOverview.LobbySlot.LobbySlotView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    xmlns:lobbySlot="clr-namespace:OutbreakTracker2.Application.Views.Dashboard.ClientOverview.LobbySlot"
    xmlns:converters="clr-namespace:OutbreakTracker2.Application.Converters"
    d:DesignHeight="300"
    d:DesignWidth="220"
    x:DataType="lobbySlot:LobbySlotViewModel"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:LobbySlotStatusToIconConverter x:Key="LobbySlotStatusToIconConverter" />
        <converters:LobbyVersionToIconConverter x:Key="LobbyVersionToIconConverter" />
    </UserControl.Resources>

    <suki:GlassCard
        MinWidth="180"
        MaxWidth="260"
        Margin="3">
        <StackPanel Margin="5" Spacing="4">

            <!--  Header: slot number (top-left) + lock/unlock icon (top-right)  -->
            <Grid ColumnDefinitions="*, Auto">
                <TextBlock
                    Grid.Column="0"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Text="{Binding SlotNumber, StringFormat='Slot: {0}'}" />
                <avalonia:MaterialIcon
                    Grid.Column="1"
                    Width="18"
                    Height="18"
                    Foreground="{Binding LockForeground}"
                    Kind="{Binding IsPasswordProtectedBool, Converter={x:Static converters:BoolToIconConverters.Password}}"
                    ToolTip.Tip="Password Protected Status" />
            </Grid>

            <!--  Scenario image (30% smaller: 140×140)  -->
            <Image
                Width="140"
                Height="140"
                HorizontalAlignment="Center"
                Source="{Binding ScenarioImageViewModel.ScenarioImage}"
                Stretch="Uniform" />

            <!--  Title  -->
            <DockPanel Margin="0,2">
                <avalonia:MaterialIcon
                    DockPanel.Dock="Left"
                    Width="15"
                    Height="15"
                    Kind="FormatTitle"
                    ToolTip.Tip="Room Title" />
                <TextBlock
                    DockPanel.Dock="Left"
                    Margin="3,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="Title:" />
                <TextBlock
                    Margin="3,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Text="{Binding Title}"
                    TextTrimming="CharacterEllipsis" />
            </DockPanel>

            <!--  Status  -->
            <DockPanel Margin="0,2">
                <avalonia:MaterialIcon
                    DockPanel.Dock="Left"
                    Width="15"
                    Height="15"
                    Kind="{Binding Status, Converter={StaticResource LobbySlotStatusToIconConverter}}"
                    ToolTip.Tip="Room Status" />
                <TextBlock
                    DockPanel.Dock="Left"
                    Margin="3,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="Status:" />
                <TextBlock
                    Margin="3,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Text="{Binding Status}"
                    TextTrimming="CharacterEllipsis" />
            </DockPanel>

            <!--  Players  -->
            <DockPanel Margin="0,2">
                <avalonia:MaterialIcon
                    DockPanel.Dock="Left"
                    Width="15"
                    Height="15"
                    Kind="AccountGroup"
                    ToolTip.Tip="Number of Players" />
                <TextBlock
                    DockPanel.Dock="Left"
                    Margin="3,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="Players:" />
                <TextBlock
                    Margin="3,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Text="{Binding PlayersDisplay}" />
            </DockPanel>

            <!--  Scenario  -->
            <DockPanel Margin="0,2">
                <avalonia:MaterialIcon
                    DockPanel.Dock="Left"
                    Width="15"
                    Height="15"
                    Kind="GamepadVariantOutline"
                    ToolTip.Tip="Scenario Name" />
                <TextBlock
                    DockPanel.Dock="Left"
                    Margin="3,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="Scenario:" />
                <TextBlock
                    Margin="3,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Text="{Binding ScenarioId}"
                    TextTrimming="CharacterEllipsis" />
            </DockPanel>

            <!--  Version  -->
            <DockPanel Margin="0,2">
                <avalonia:MaterialIcon
                    DockPanel.Dock="Left"
                    Width="15"
                    Height="15"
                    Kind="{Binding Version, Converter={StaticResource LobbyVersionToIconConverter}}"
                    ToolTip.Tip="Game Version" />
                <TextBlock
                    DockPanel.Dock="Left"
                    Margin="3,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="Version:" />
                <TextBlock
                    Margin="3,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Text="{Binding Version}"
                    TextTrimming="CharacterEllipsis" />
            </DockPanel>

        </StackPanel>
    </suki:GlassCard>
</UserControl>