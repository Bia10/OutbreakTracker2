<UserControl
    x:Class="OutbreakTracker2.Application.Views.Dashboard.ClientOverview.InGameEnemy.InGameEnemyView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    xmlns:inGameEnemy="clr-namespace:OutbreakTracker2.Application.Views.Dashboard.ClientOverview.InGameEnemy"
    d:DesignHeight="300"
    d:DesignWidth="400"
    x:DataType="inGameEnemy:InGameEnemyViewModel"
    mc:Ignorable="d">

    <suki:GlassCard
        Margin="4,3"
        Padding="8,6"
        BorderBrush="{Binding BorderBrush}"
        BorderThickness="2"
        CornerRadius="6">

        <StackPanel Spacing="4">

            <TextBlock
                FontSize="13"
                FontWeight="Bold"
                Text="{Binding Name}"
                TextTrimming="CharacterEllipsis" />

            <!-- HP bar with cur/max values overlaid inside -->
            <Grid>
                <ProgressBar
                    Height="18"
                    Maximum="100"
                    Value="{Binding HealthPercentage}" />
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Text="{Binding HealthStatus}" />
            </Grid>

            <!-- Details -->
            <Grid
                Margin="0,2,0,0"
                ColumnDefinitions="Auto,*"
                RowDefinitions="Auto,Auto,Auto">
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,6,1"
                    FontSize="11"
                    Foreground="{DynamicResource SukiLowText}"
                    Text="Boss Type:" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    FontSize="11"
                    Text="{Binding BossType}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,0,6,1"
                    FontSize="11"
                    Foreground="{DynamicResource SukiLowText}"
                    Text="Room:" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    FontSize="11"
                    Text="{Binding RoomName}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="0,0,6,0"
                    FontSize="11"
                    Foreground="{DynamicResource SukiLowText}"
                    Text="Status:" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    FontSize="11"
                    Text="{Binding Status}" />
            </Grid>

        </StackPanel>
    </suki:GlassCard>
</UserControl>