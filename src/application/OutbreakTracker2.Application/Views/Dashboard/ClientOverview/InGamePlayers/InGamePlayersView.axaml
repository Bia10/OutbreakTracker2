<UserControl
    x:Class="OutbreakTracker2.Application.Views.Dashboard.ClientOverview.InGamePlayers.InGamePlayersView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:common="clr-namespace:OutbreakTracker2.Application.Views.Common"
    xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    xmlns:inGamePlayers="clr-namespace:OutbreakTracker2.Application.Views.Dashboard.ClientOverview.InGamePlayers"
    xmlns:inGamePlayer="clr-namespace:OutbreakTracker2.Application.Views.Dashboard.ClientOverview.InGamePlayer"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="inGamePlayers:InGamePlayersViewModel"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer
            HorizontalScrollBarVisibility="Disabled"
            IsVisible="{Binding HasPlayers}"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding PlayersView}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding PlayerColumnCount}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <suki:GlassCard
                            Margin="10"
                            Padding="15"
                            CornerRadius="10">
                            <inGamePlayer:InGamePlayerView />
                        </suki:GlassCard>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <common:NotInGameWatermark
            IsVisible="{Binding !HasPlayers}"
            Message="No active players — not in-game" />
    </Grid>
</UserControl>