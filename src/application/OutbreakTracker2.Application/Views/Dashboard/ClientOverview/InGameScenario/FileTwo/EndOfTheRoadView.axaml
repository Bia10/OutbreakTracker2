<UserControl
    x:Class="OutbreakTracker2.Application.Views.Dashboard.ClientOverview.InGameScenario.FileTwo.EndOfTheRoadView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fileTwo="clr-namespace:OutbreakTracker2.Application.Views.Dashboard.ClientOverview.InGameScenario.FileTwo"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="fileTwo:EndOfTheRoadViewModel"
    mc:Ignorable="d">

    <StackPanel Margin="0,4" Spacing="2">
        <TextBlock
            FontSize="10"
            FontWeight="SemiBold"
            Foreground="{DynamicResource SukiLowText}"
            Text="End of the Road" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="11"
                FontWeight="SemiBold"
                Text="First Door Passcode:" />
            <TextBlock
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="Bold"
                Text="{Binding EndOfRoadDisplay}" />
        </StackPanel>
    </StackPanel>
</UserControl>