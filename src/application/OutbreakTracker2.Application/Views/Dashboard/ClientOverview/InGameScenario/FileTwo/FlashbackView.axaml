<UserControl
x:Class="OutbreakTracker2.Application.Views.Dashboard.ClientOverview.InGameScenario.FileTwo.FlashbackView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:fileTwo="clr-namespace:OutbreakTracker2.Application.Views.Dashboard.ClientOverview.InGameScenario.FileTwo"
d:DesignHeight="450"
d:DesignWidth="800"
x:DataType="fileTwo:FlashbackViewModel"
mc:Ignorable="d">

    <StackPanel Margin="0,4" Spacing="2">
        <TextBlock
        FontSize="10"
        FontWeight="SemiBold"
        Foreground="{DynamicResource SukiLowText}"
        Text="Flashback" />
        <StackPanel
        IsVisible="{Binding FlashbackTimeDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
        Orientation="Horizontal"
        Spacing="8">
            <TextBlock
            VerticalAlignment="Center"
            FontSize="11"
            FontWeight="SemiBold"
            Text="Time Remaining:" />
            <TextBlock
            VerticalAlignment="Center"
            FontSize="16"
            FontWeight="Bold"
            Text="{Binding FlashbackTimeDisplay}" />
        </StackPanel>
    </StackPanel>
</UserControl>
