<UserControl
x:Class="OutbreakTracker2.Application.Views.Dashboard.ClientAlreadyRunning.ClientAlreadyRunningView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:clientAlreadyRunning1="clr-namespace:OutbreakTracker2.Application.Views.Dashboard.ClientAlreadyRunning"
xmlns:launcher="clr-namespace:OutbreakTracker2.Application.Services.Launcher"
d:DesignHeight="450"
d:DesignWidth="800"
x:Name="Root"
x:DataType="clientAlreadyRunning1:ClientAlreadyRunningViewModel"
mc:Ignorable="d">
    <StackPanel Margin="10">
        <TextBlock
        Margin="0,0,0,10"
        FontSize="16"
        Text="Existing PCSX2 Processes Found" />
        <ItemsControl x:Name="ProcessesItemsControl" ItemsSource="{Binding RunningProcessesView}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="launcher:ProcessModel">
                    <Border
                    Margin="0,5"
                    Padding="10"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="5">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock FontWeight="Bold" Text="{Binding Name}" />
                                <TextBlock Text="{Binding Id, StringFormat='Process ID: {0}'}" />
                                <TextBlock Text="{Binding StartTime, StringFormat='Started: {0:g}'}" />
                            </StackPanel>
                            <StackPanel
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Spacing="5">
                                <Button
                                Command="{Binding #Root.((clientAlreadyRunning1:ClientAlreadyRunningViewModel)DataContext).AttachToProcessCommand}"
                                CommandParameter="{Binding Id}"
                                Content="Attach to Process" />
                                <Button
                                Command="{Binding #Root.((clientAlreadyRunning1:ClientAlreadyRunningViewModel)DataContext).TerminateProcessCommand}"
                                CommandParameter="{Binding Id}"
                                Content="Terminate Process" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>