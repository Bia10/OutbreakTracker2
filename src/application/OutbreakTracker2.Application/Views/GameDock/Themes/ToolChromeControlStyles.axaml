<!--
Local ToolChromeControl augmentation for floating windows.

Widens the grip hit target when a tool is floating so that
HostWindow drag detection works reliably.
-->
<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="ToolChromeControl:floating /template/ Grid#PART_Grip">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="MinHeight" Value="28" />
    </Style>

    <Style Selector="ToolChromeControl:floating /template/ TextBlock#PART_Title">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

</Styles>