<UserControl
    x:Class="OutbreakTracker2.Application.Views.GameDock.GameDockView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:gameDock="clr-namespace:OutbreakTracker2.Application.Views.GameDock"
    xmlns:dockables="clr-namespace:OutbreakTracker2.Application.Views.GameDock.Dockables"
    xmlns:embeddedGame="clr-namespace:OutbreakTracker2.Application.Views.Dashboard.ClientOverview.EmbeddedGame"
    xmlns:inGameEnemies="clr-namespace:OutbreakTracker2.Application.Views.Dashboard.ClientOverview.InGameEnemies"
    xmlns:inGamePlayers="clr-namespace:OutbreakTracker2.Application.Views.Dashboard.ClientOverview.InGamePlayers"
    xmlns:inGameScenario="clr-namespace:OutbreakTracker2.Application.Views.Dashboard.ClientOverview.InGameScenario"
    d:DesignHeight="600"
    d:DesignWidth="1200"
    x:DataType="gameDock:GameDockViewModel"
    mc:Ignorable="d">

    <!--
        DataTemplates map each IDockable subtype to its content view.
        The Dock library renders these inside ToolControl / DocumentControl.
    -->
    <UserControl.DataTemplates>

        <!-- Centre: embedded game window -->
        <DataTemplate DataType="{x:Type dockables:GameScreenDocument}">
            <embeddedGame:EmbeddedGameTabView DataContext="{Binding EmbeddedGameViewModel}" />
        </DataTemplate>

        <!-- Left: mob / enemy list -->
        <DataTemplate DataType="{x:Type dockables:EnemyListDockTool}">
            <inGameEnemies:InGameEnemiesView DataContext="{Binding InGameEnemiesViewModel}" />
        </DataTemplate>

        <!-- Right top: players -->
        <DataTemplate DataType="{x:Type dockables:PlayersDockTool}">
            <inGamePlayers:InGamePlayersView DataContext="{Binding InGamePlayersViewModel}" />
        </DataTemplate>

        <!-- Right bottom: scenario info -->
        <DataTemplate DataType="{x:Type dockables:ScenarioInfoDockTool}">
            <inGameScenario:InGameScenarioView DataContext="{Binding InGameScenarioViewModel}" />
        </DataTemplate>

    </UserControl.DataTemplates>

    <DockControl
        Margin="0"
        Layout="{Binding Layout}"
        InitializeLayout="False"
        InitializeFactory="False" />

</UserControl>
