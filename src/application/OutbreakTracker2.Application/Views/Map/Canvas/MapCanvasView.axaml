<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:canvas="clr-namespace:OutbreakTracker2.Application.Views.Map.Canvas"
             xmlns:common="clr-namespace:OutbreakTracker2.Application.Views.Common"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="OutbreakTracker2.Application.Views.Map.Canvas.MapCanvasView"
             x:DataType="canvas:MapCanvasViewModel">
    <Grid>
        <!-- Canvas: only shown when in-game; background deferred until a scenario map is loaded -->
        <Border BorderBrush="Gray" BorderThickness="1" IsVisible="{Binding IsInGame}">
            <Grid>
                <Canvas x:Name="GameMapCanvas"
                        Background="DimGray"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        ClipToBounds="True" />

                <!-- Overlay: zoom controls (top-right) -->
                <StackPanel HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="4"
                            Spacing="4">
                    <Button Content="⟳ Reset"
                            Padding="4,2"
                            FontSize="9"
                            Click="OnResetZoomClick"
                            ToolTip.Tip="Reset zoom and pan&#x0a;Scroll to zoom · Drag to pan" />
                </StackPanel>

                <!-- Overlay: zoom level indicator (bottom-left) -->
                <TextBlock x:Name="ZoomLabel"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Bottom"
                           Margin="4"
                           Foreground="White"
                           FontSize="9"
                           Opacity="0.7" />
            </Grid>
        </Border>

        <!-- Watermark: shown while not in-game -->
        <common:NotInGameWatermark
            IsVisible="{Binding !IsInGame}"
            Message="Not in-game&#x0a;Map loads when a scenario begins" />
    </Grid>
</UserControl>